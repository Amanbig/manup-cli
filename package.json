{
  "name": "manup-cli",
  "version": "0.1.0",
  "description": "This is the CLI for ManUp secrets vault (https://github.com/Amanbig/ManUp)",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "manup": "./bin/manup.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "manup",
    "secrets",
    "vault",
    "cli",
    "environment-variables",
    "infisical"
  ],
  "author": "Amanpreet",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "axios": "^1.8.1",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "conf": "^13.1.0",
    "dotenv": "^16.4.7",
    "execa": "^9.6.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.9",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
